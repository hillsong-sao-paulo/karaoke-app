{
  "name": "karaoke-sisterhood",
  "version": "1.0.0",
  "description": "App de listagem e abertura de músicas para o evento Karaokê Sisterhood Night",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "pdf": "node scripts/generate-list-pdf.js"
  },
  "build": {
    "appId": "com.karaoke.sistema",
    "productName": "Sistema de Karaokê",
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dir"
      ],
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "pdfkit": "^0.17.2"
  }
}
